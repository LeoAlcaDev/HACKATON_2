# URL base del backend del curso. El TA la entrega el día del evento e incluye el
# prefijo /api/v1. Es la única variable obligatoria; sin ella la app no arranca.
VITE_API_BASE_URL=https://<backend-url>/api/v1

# Prellenado opcional del formulario de login, solo por comodidad en desarrollo.
# OJO: las variables VITE_ quedan expuestas en el bundle público, así que nunca
# pongas aquí el password del equipo.
VITE_TEAM_CODE=TEAM-0XX
VITE_EMAIL=operator@tuckersoft.com
